<!--
  Trade Genius — Permissions à ajouter dans AndroidManifest.xml

  À FUSIONNER DANS :
    android/app/src/main/AndroidManifest.xml

  Place les <uses-permission> à la racine du <manifest>.
  Place le <service> à l'intérieur du <application>.
-->

<!-- 1) PERMISSIONS (à ajouter à la racine du <manifest>) -->

<!-- Bulle système (overlay sur autres apps) -->
<uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

<!-- Foreground service obligatoire pour la bulle -->
<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

<!-- Notifications (Android 13+) -->
<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

<!-- Internet (déjà présent normalement) -->
<uses-permission android:name="android.permission.INTERNET" />


<!-- 2) DÉCLARER LE SERVICE (à ajouter dans <application>) -->

<service
    android:name=".BubbleService"
    android:foregroundServiceType="mediaProjection"
    android:exported="false" />


<!-- 3) IMPORTANT — Modifier le launchMode de MainActivity -->


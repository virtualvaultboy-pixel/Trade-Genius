<!--
  bubble_bg.xml — Drawable cercle dégradé bleu/violet (style FAB Analyste)

  À PLACER DANS :
    android/app/src/main/res/drawable/bubble_bg.xml
-->
<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Halo extérieur -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1F60A5FA" />
        </shape>
    </item>
    <!-- Disque principal dégradé -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:startColor="#3B82F6"
                android:endColor="#8B5CF6"
                android:type="linear" />
            <stroke
                android:width="2dp"
                android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
